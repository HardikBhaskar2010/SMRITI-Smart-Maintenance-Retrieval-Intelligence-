# ─────────────────────────────────────────────
#  SMRITI — .gitignore
#  Covers: Python backend · React/TS frontend
#  Auto-maintained — update on every major change
# ─────────────────────────────────────────────

# ── Secrets & Keys ──────────────────────────
.env
.env.local
.env.*.local
*.env
secrets/

# ── Python ──────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# pytest / testing
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml

# mypy / type checking
.mypy_cache/
.dmypy.json

# ── FastAPI / Backend Data ───────────────────
# ChromaDB vector store (large, environment-specific)
smriti-backend/data/chromadb/
# Uploaded documents (user-uploaded, not source code)
smriti-backend/data/uploads/
# Guru Mode session transcripts (runtime data)
smriti-backend/data/sessions/
# Demo query cache (pre-warmed, environment-specific)
smriti-backend/demo_cache/
# Log files
*.log
logs/

# ── Node / React Frontend ────────────────────
node_modules/
smriti-frontend/node_modules/

# Vite build output
smriti-frontend/dist/
smriti-frontend/.vite/

# PWA generated files (Workbox auto-generates these)
smriti-frontend/public/sw.js
smriti-frontend/public/workbox-*.js
smriti-frontend/public/sw.js.map

# TypeScript build info
*.tsbuildinfo
smriti-frontend/tsconfig.tsbuildinfo

# ── IDEs & Editors ───────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Operating System ─────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ── Misc ─────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/
.parcel-cache/

# Jupyter (if used for analysis)
.ipynb_checkpoints/
*.ipynb

# ── Keep these ───────────────────────────────
# Explicitly track the .env.example (template, no secrets)
!.env.example
!smriti-backend/.env.example

# Keep data directories in git (just not the contents)
!smriti-backend/data/
!smriti-backend/data/.gitkeep
